generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(FRIEND)
  createdAt DateTime @default(now())
  active    Boolean  @default(true)

  posts     Post[]
  comments  Comment[]
  reactions Reaction[]
}

enum Role {
  ADMIN
  FRIEND
  CUSTOMER
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  photos      PhotoCategory[]
}

// ─── Photos ───────────────────────────────────────────────────────────────────

model Photo {
  id          String    @id @default(cuid())
  filename    String
  storageKey  String    @unique
  url         String
  title       String?
  captureDate DateTime?
  camera      String?
  lens        String?
  exifRaw     Json?
  createdAt   DateTime  @default(now())

  categories  PhotoCategory[]
  albums      AlbumPhoto[]
  comments    Comment[]
  reactions   Reaction[]
}

model PhotoCategory {
  photoId    String
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([photoId, categoryId])
}

// ─── Albums ───────────────────────────────────────────────────────────────────

model Album {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?
  location    String?
  date        DateTime?
  createdAt   DateTime    @default(now())

  photos      AlbumPhoto[]
}

model AlbumPhoto {
  photoId  String
  photo    Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  albumId  String
  album    Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  order    Int    @default(0)

  @@id([photoId, albumId])
}

// ─── Posts (social feed) ──────────────────────────────────────────────────────

model Post {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  description String
  photoUrl    String?
  createdAt   DateTime @default(now())

  comments    Comment[]
  reactions   Reaction[]
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String
  coverPhotoUrl String
  publishedAt   DateTime
  readingTime   Int
  content       Json
  sourceFile    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  comments      Comment[]
  reactions     Reaction[]
}

// ─── Comments ─────────────────────────────────────────────────────────────────
//
// Top-level comment: one of postId / photoId / blogPostId is set, parentId null.
// Reply: parentId is set, target FK columns null.

model Comment {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  postId     String?
  post       Post?     @relation(fields: [postId], references: [id])
  photoId    String?
  photo      Photo?    @relation(fields: [photoId], references: [id])
  blogPostId String?
  blogPost   BlogPost? @relation(fields: [blogPostId], references: [id])

  reactions  Reaction[]
}

// ─── Reactions ────────────────────────────────────────────────────────────────
//
// One emoji per user per target. @@unique per FK fires only when FK is not null
// (Postgres UNIQUE ignores NULLs), so multiple nulls are allowed.

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  emoji     String
  createdAt DateTime @default(now())

  postId     String?
  post       Post?     @relation(fields: [postId], references: [id])
  photoId    String?
  photo      Photo?    @relation(fields: [photoId], references: [id])
  blogPostId String?
  blogPost   BlogPost? @relation(fields: [blogPostId], references: [id])
  commentId  String?
  comment    Comment?  @relation(fields: [commentId], references: [id])

  @@unique([userId, postId])
  @@unique([userId, photoId])
  @@unique([userId, blogPostId])
  @@unique([userId, commentId])
}

// ─── Subscribers ──────────────────────────────────────────────────────────────

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}
